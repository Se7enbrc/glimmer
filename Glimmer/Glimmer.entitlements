<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Glimmer runs UNSANDBOXED: it registers a root AWDL LaunchDaemon via
	     SMAppService, which App Sandbox forbids. Stays Hardened Runtime +
	     Developer-ID + notarized; MAS was already out (device.usb + library
	     validation). Rationale + threat model: docs/SECURITY.md. Unsandboxed
	     needs no network/files/device/temporary-exception keys - only the
	     Hardened-Runtime ones remain. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Hardened Runtime library validation, disabled so the embedded openssl@3
	     / opus dylibs load. Re-enable once they're signed under our Team ID at
	     build time (tracked with the RCE-hardening pass). -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Hardened Runtime: no JIT. -->
	<key>com.apple.security.cs.allow-jit</key>
	<false/>
</dict>
</plist>
