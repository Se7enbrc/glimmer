<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Helper is sandboxed to match the main app. No special entitlements
	     needed - `NSWorkspace.openApplication` works under app-sandbox to
	     launch siblings of the same bundle. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
</dict>
</plist>
